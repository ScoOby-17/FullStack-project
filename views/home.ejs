<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">

    <!-- Bootstrap (ONLY for navbar & footer) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        /* HERO SECTION */
        .hero {
            height: 80vh;
            background: url("https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=1600") no-repeat center/cover;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
        }

        .hero h1 {
            font-size: 3rem;
            font-weight: bold;
        }

        .hero p {
            font-size: 1.2rem;
            margin-top: 10px;
        }

        .hero a {
            display: inline-block;
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #fe424d;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

        /* FEATURED SECTION */
        .featured {
            padding: 50px 20px;
        }

        .featured h2 {
            text-align: center;
            margin-bottom: 30px;
        }

        .cards {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .card-custom {
            width: 300px;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            transition: 0.3s;
            background: white;
        }

        .card-custom:hover {
            transform: scale(1.05);
        }

        .card-custom img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .card-body-custom {
            padding: 15px;
        }

        .card-body-custom h5 {
            margin-bottom: 10px;
        }

        .card-body-custom a {
            text-decoration: none;
            color: #fe424d;
            font-weight: bold;
        }
    </style>
</head>

<body>

    <!-- Navbar (Bootstrap) -->
    <nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">

      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link active" aria-current="page" href="/">Home</a>
        <a class="nav-link" href="/listings">All Listings</a>
        <a class="nav-link" href="/new">Add New Listing</a>
      </div>
    </div>
  </div>
</nav>

    <!-- HERO -->
    <section class="hero">
        <div>
            <h1>Explore the World 🌍</h1>
            <p>Discover unique places to stay with WanderLust</p>
            <a href="/listings">Explore Now</a>
        </div>
    </section>

    <!-- FEATURED -->
    <section class="featured">
        <h2>Featured Listings</h2>

        <div class="cards">

            <div class="card-custom">
                <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=800">
                <div class="card-body-custom">
                    <h5>Beach House</h5>
                    <p>Relax near the sea.</p>
                    <a href="/listings">View</a>
                </div>
            </div>

            <div class="card-custom">
                <img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?q=80&w=800">
                <div class="card-body-custom">
                    <h5>Mountain Stay</h5>
                    <p>Peaceful mountain vibes.</p>
                    <a href="/listings">View</a>
                </div>
            </div>

            <div class="card-custom">
                <img src="https://images.unsplash.com/photo-1494526585095-c41746248156?q=80&w=800">
                <div class="card-body-custom">
                    <h5>City Apartment</h5>
                    <p>Live in the heart of city.</p>
                    <a href="/listings">View</a>
                </div>
            </div>

        </div>
    </section>

    <!-- Footer (Bootstrap) -->
    <footer class="bg-light text-center p-3">
        <div class="f-info">
            <div class="f-info-socials mb-2">
                <i class="fa-brands fa-square-facebook"></i>
                <i class="fa-brands fa-square-instagram"></i>
                <i class="fa-brands fa-linkedin"></i>
                
            </div>
            <div>Wanderlust Private Limited <i class="fa-solid fa-copyright"></i> </div>
            <div>
                <a href="/privacy">Privacy</a> |
                <a href="/terms">Terms</a>
            </div>
        </div>
    </footer>

</body>
</html>