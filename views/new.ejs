<% layout('layouts/boilerplate.ejs') -%>

<body>
    <div class="row"></div>
    <div class="col-8 offset-2">
    <h2>Write inforamtion about Listing</h2>
    
    <form action="/listings" method="POST">
        <div class="mb-3">
            <label for="title" class="form-lable">Title</label>
            <input type="text" 
                placeholder="Write Title" 
                name="title"
                class="form-control"
            />
        </div>
        
        <div class="mb-3">
            <label for="description" class="form-lable">Description</label>
            <textarea name="description" 
                placeholder="write description" 
                type="text" 
                class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label for="image" class="form-lable">Image URL</label>
            <input type="text" 
                placeholder="Write image URL" 
                name="image" 
                class="form-control"
            />
        </div>
        
        <div class="mb-3">
            <label for="price" class="form-lable">Price</label>
            <input type="text" 
                placeholder="Write price" 
                name="price"
                class="form-control" 
            />
        </div>
        
        <div class="mb-3">
            <label for="location" class="form-lable">Location</label>
            <input type="text" 
                placeholder="Write location" 
                name="location" 
                class="form-control" 
            />
        </div>
        
        <div class="mb-3">
            <label for="country" class="form-lable">Country</label>
            <input type="text" 
                placeholder="Write country" 
                name="country" 
                class="form-control"
            />
        </div>
        
        <br><br>

        <button style="background-color: #fe424d; color: aliceblue; border-radius: 3px ; border: #fe424d;">Add</button>
    </form>
    </div>
    </div>
</body>
